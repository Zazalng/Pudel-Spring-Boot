# ===========================================
# Pudel Discord Bot - Environment Configuration
# Copy this file to .env and fill in your values
# ===========================================

# ===========================================
# Server Configuration
# ===========================================
SERVER_PORT=8080
# Swagger Enable?
SWAGGER_ENABLED=true
SWAGGER_ACCESS_PROTECTED=true

# ===========================================
# PostgreSQL Database Configuration
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASS=pudelpassword
POSTGRES_DB=pudel

# ===========================================
# Discord Bot Configuration (REQUIRED)
# Get these from https://discord.com/developers/applications
# ===========================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost/auth/callback

# ===========================================
# Security Configuration (RSA Keys for JWT)
# ===========================================
# Key filenames (used by Docker to construct paths)
JWT_PRIVATE_KEY_FILE=pv.key
JWT_PUBLIC_KEY_FILE=pb.key
# Full paths (for non-Docker usage)
JWT_PRIVATE_KEY_PATH=keys/pv.key
JWT_PUBLIC_KEY_PATH=keys/pb.key
JWT_EXPIRATION=604800000

# ===========================================
# Pudel Branding (Dynamic name)
# To kept Instance same as Project remove these 2 variables
# For version, can edit on application.yml on your fork or using .env + docker-compose.yml
# ===========================================
PUDEL_BRANDING_NAME=
PUDEL_BRANDING_CODENAME=
#PUDEL_BRANDING_VERSION=UNCOMMENT-TO-USE

# ===========================================
# Admin Panel Configuration (Mutual RSA Auth)
# The owner is the initial admin who can add other admins
# ===========================================
PUDEL_ADMIN_INITIAL_OWNER=12345678901234567
# Public key filename for owner (in keys/ directory)
PUDEL_ADMIN_OWNER_PUBLIC_KEY_FILE=owner_pb.key

# ===========================================
# Plugin Configuration
# Plugins are auto-detected from the plugins directory
# In Docker, plugins dir is bind-mounted for live updates
# ===========================================
PUDEL_PLUGIN_DIRECTORY=plugins
PUDEL_PLUGIN_ENABLE_AUTO_DISCOVERY=true
PUDEL_PLUGIN_ENABLE_AUTO_LOAD=true
# Retry interval for failed plugins (milliseconds)
PUDEL_PLUGIN_RETRY_INTERVAL=30000
# Maximum retry attempts before waiting for JAR update
PUDEL_PLUGIN_MAX_RETRIES=3

# ===========================================
# CORS Configuration
# Comma-separated list of allowed origins
# In production, include your frontend domain AND API domain
# Example: https://worldstandard.group,https://pudel.worldstandard.group
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ===========================================
# Ollama LLM Configuration
# Local AI for intelligent chatbot responses
#
# NOTE: Ollama container only starts with --profile ollama
# Usage: docker-compose --profile ollama up -d
#
# OLLAMA_ENABLED controls Pudel's AI features, not the container
# ===========================================
OLLAMA_ENABLED=true
# Use 'ollama' for Docker (container name), 'localhost' for local install
OLLAMA_URL=http://ollama:11434
OLLAMA_PORT=11434
# Available LOCAL models: qwen3:8b, llama3.1:8b, mistral:7b, phi3:mini, etc.
OLLAMA_MODEL=qwen3:8b
# Ollama Cloud Model Authentication (If model was not cloud this can be empty)
OLLAMA_TOKEN=

# ===========================================
# Embedding Configuration
# Used for semantic search and memory
# ===========================================
EMBEDDING_ENABLED=true
# Available models: qwen3-embedding:8b, nomic-embed-text, etc.
EMBEDDING_MODEL=qwen3-embedding:8b

# ===========================================
# JVM Configuration
# Adjust based on your server resources
# Do NOT wrap in quotes - Docker Compose handles quoting automatically
# Quotes here become literal characters and break Java startup
# ===========================================
JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:+UseStringDeduplication
