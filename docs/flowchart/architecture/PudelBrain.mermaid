%% Pudel Brain Architecture v2.3.0
%% PudelBrain v2 — Ollama completion-focused with passive context, dialogue history, MCP tools

flowchart TD
    subgraph Input["📨 Input"]
        MESSAGE[/"User Message<br/>@Pudel how are you?"/]
    end

    subgraph Discord["🎮 Discord Handling"]
        TYPING["sendTyping().queue()<br/>Non-blocking"]
        SEND["sendMessage().queue()<br/>Async response"]
    end

    subgraph Analysis["🔍 Text Analysis"]
        ANALYZER["EntityExtractor<br/>extractEntities()"]
        INTENT["Intent Detection"]
        SENTIMENT["Sentiment Analysis"]
    end

    subgraph Context["🧠 Context Gathering"]
        PASSIVE["PassiveContextProcessor<br/>getRecentContext()"]
        DIALOGUE["DialogueHistoryManager<br/>getRecentHistory()"]
        PERSONALITY["SystemPromptBuilder<br/>buildSystemPrompt()"]
    end

    subgraph Generation["💬 Response Generation"]
        PROMPT["Build Prompt<br/>+ System Prompt<br/>+ Context<br/>+ Personality"]
        OLLAMA["OllamaClient<br/>generateStreaming()"]
        MARKDOWN["ensureDiscordMarkdown()<br/>truncateForDiscord()"]
    end

    subgraph Agent["🤖 Agent System (optional)"]
        AGENT_CHECK{"Data management<br/>intent?"}
        AGENT_SVC["PudelAgentService<br/>processWithTools()"]
        MCP_TOOLS["MCP Tools<br/>get_passive_context<br/>get_dialogue_history<br/>get_message_by_id<br/>get_forwarded_messages<br/>get_brain_status"]
        AGENT_TOOLS["Agent Tools<br/>create_table, store_data<br/>search_data, remember/recall"]
    end

    subgraph Storage["💾 Storage"]
        STORE_DIALOGUE["DialogueHistoryManager<br/>storeDialogue()<br/>respond_to tracking"]
        STORE_CONTEXT["PassiveContextProcessor<br/>submit() → batch process<br/>message_id, entities JSONB"]
    end

    subgraph Output["📤 Output"]
        RESPONSE[/"Bot Response<br/>Discord Markdown formatted"/]
    end

    %% Flow
    MESSAGE --> TYPING
    TYPING --> ANALYZER
    ANALYZER --> INTENT
    ANALYZER --> SENTIMENT

    INTENT --> AGENT_CHECK
    AGENT_CHECK -->|"Yes"| AGENT_SVC
    AGENT_SVC --> MCP_TOOLS
    AGENT_SVC --> AGENT_TOOLS
    AGENT_TOOLS --> RESPONSE

    AGENT_CHECK -->|"No"| PASSIVE
    PASSIVE --> DIALOGUE
    DIALOGUE --> PERSONALITY
    PERSONALITY --> PROMPT
    PROMPT --> OLLAMA
    OLLAMA --> MARKDOWN
    MARKDOWN --> SEND
    SEND --> RESPONSE

    %% Storage
    SEND --> STORE_DIALOGUE
    MESSAGE --> STORE_CONTEXT

    %% Styling
    classDef input fill:#1565c0,stroke:#0d47a1,color:#fff
    classDef discord fill:#5865F2,stroke:#4752C4,color:#fff
    classDef analysis fill:#7b1fa2,stroke:#4a148c,color:#fff
    classDef context fill:#00796b,stroke:#004d40,color:#fff
    classDef generation fill:#2e7d32,stroke:#1b5e20,color:#fff
    classDef agent fill:#c62828,stroke:#b71c1c,color:#fff
    classDef storage fill:#f57c00,stroke:#e65100,color:#fff
    classDef output fill:#455a64,stroke:#263238,color:#fff

    class MESSAGE input
    class TYPING,SEND discord
    class ANALYZER,INTENT,SENTIMENT analysis
    class PASSIVE,DIALOGUE,PERSONALITY context
    class PROMPT,OLLAMA,MARKDOWN generation
    class AGENT_CHECK,AGENT_SVC,MCP_TOOLS,AGENT_TOOLS agent
    class STORE_DIALOGUE,STORE_CONTEXT storage
    class RESPONSE output
