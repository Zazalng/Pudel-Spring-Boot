%% Pudel Passive Context Processor
%% Collects messages Pudel observes but doesn't respond to
%% Schema (passive_context + forwarded_messages) is reconciled from Java
%% (SchemaManagementService); message_id is UNIQUE to back ON CONFLICT upserts.

flowchart TD
    subgraph Input["📨 Message Stream"]
        MSG1[/"Message 1<br/>User: Hello everyone"/]
        MSG2[/"Message 2<br/>User: Check this out!"/]
        MSG3[/"Message 3<br/>User: [image.png]"/]
        MSG_N[/"..."/]
    end

    subgraph Queue["📋 ConcurrentLinkedQueue"]
        QUEUE["PendingContext Queue<br/>maxQueueSize: 200"]
        DEDUP["Deduplication<br/>userId:channelId → messageId<br/>keeps newest only"]
    end

    subgraph Processor["⚙️ PassiveContextProcessor"]
        SUBMIT["submit()<br/>with targetId + isGuild"]
        BATCH["@Scheduled processBatch()<br/>batchSize: 5<br/>processingIntervalMs: 1000"]
        EXPIRE["Age Expiration<br/>maxAgeMs: 120000<br/>(2 minutes)"]
    end

    subgraph Processing["🔄 Processing Pipeline"]
        BUILD["buildContextEntry()<br/>Extract from MessageReceivedEvent"]
        EXTRACT["EntityExtractor<br/>extractEntities()<br/>users, channels, roles<br/>emojis, URLs, attachments"]
        ATTACH["extractAttachmentUrls()<br/>Discord CDN links"]
        REPLY["Capture reply_to<br/>message.getReferencedMessage()"]
        FORWARD["buildForwardedRefs()<br/>From embeds"]
    end

    subgraph Storage["💾 Database Storage"]
        PC_TABLE["passive_context table<br/>message_id BIGINT UNIQUE<br/>user_id, channel_id<br/>content TEXT<br/>entities JSONB<br/>attachment_urls TEXT[]<br/>forwarded_content JSONB<br/>created_at TIMESTAMP"]
        FWD_TABLE["forwarded_messages table<br/>passive_context_id FK<br/>message_id, author_id<br/>author_name, content"]
    end

    subgraph Retrieval["🔍 Retrieval (via MCP Tools"]
        GET_RECENT["get_passive_context<br/>getRecentContext()<br/>channelId + limit"]
        GET_BY_ID["get_message_by_id<br/>fetchByMessageId()<br/>messageId lookup"]
        GET_FWD["get_forwarded_messages<br/>loadForwardedMessages()<br/>from forwarded_messages table"]
    end

    subgraph Stats["📊 Statistics"]
        SUBMITTED["totalSubmitted"]
        PROCESSED["totalProcessed"]
        EXPIRED["totalExpired"]
        DEDUPLICATED["totalDeduplicated"]
    end

    %% Flow
    MSG1 -->|"trackContext()"| SUBMIT
    MSG2 -->|"trackContext()"| SUBMIT
    MSG3 -->|"trackContext()"| SUBMIT
    MSG_N -->|"trackContext()"| SUBMIT

    SUBMIT --> QUEUE
    QUEUE --> DEDUP
    DEDUP --> BATCH

    BATCH --> EXPIRE
    EXPIRE -->|"expired"| Stats
    EXPIRE -->|"ready"| BUILD

    BUILD --> EXTRACT
    BUILD --> ATTACH
    BUILD --> REPLY
    BUILD --> FORWARD

    EXTRACT --> PC_TABLE
    ATTACH --> PC_TABLE
    REPLY --> PC_TABLE
    FORWARD --> FWD_TABLE

    PC_TABLE --> Stats

    %% Retrieval
    GET_RECENT -->|"query by channel_id<br/>ORDER BY created_at DESC"| PC_TABLE
    GET_BY_ID -->|"query by message_id"| PC_TABLE
    GET_FWD -->|"JOIN forwarded_messages"| FWD_TABLE

    %% Styling
    classDef input fill:#1565c0,stroke:#0d47a1,color:#fff
    classDef queue fill:#7b1fa2,stroke:#4a148c,color:#fff
    classDef processor fill:#00796b,stroke:#004d40,color:#fff
    classDef processing fill:#2e7d32,stroke:#1b5e20,color:#fff
    classDef storage fill:#f57c00,stroke:#e65100,color:#fff
    classDef retrieval fill:#1a237e,stroke:#0d47a1,color:#fff
    classDef stats fill:#455a64,stroke:#263238,color:#fff

    class MSG1,MSG2,MSG3,MSG_N input
    class QUEUE,DEDUP queue
    class SUBMIT,BATCH,EXPIRE processor
    class BUILD,EXTRACT,ATTACH,REPLY,FORWARD processing
    class PC_TABLE,FWD_TABLE storage
    class GET_RECENT,GET_BY_ID,GET_FWD retrieval
    class SUBMITTED,PROCESSED,EXPIRED,DEDUPLICATED stats
