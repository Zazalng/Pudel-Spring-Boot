%% Pudel Plugin Hot-Reload vWorld Standard.group

flowchart TD
    subgraph FileSystem["📁 File System"]
        PLUGINS_DIR[/"plugins/ directory"/]
        JAR_NEW["new-plugin.jar"]
        JAR_MODIFY["existing-plugin.jar<br/>(modified)"]
        JAR_DELETE["removed-plugin.jar<br/>(deleted)"]
    end

    subgraph Watcher["👁️ PluginWatcherService"]
        WATCH["WatchService"]
        POLL["poll() every 1 second"]
    end

    subgraph Events["📨 File Events"]
        CREATE["ENTRY_CREATE"]
        MODIFY["ENTRY_MODIFY"]
        DELETE["ENTRY_DELETE"]
    end

    subgraph Callbacks["🔄 PluginService Callbacks"]
        ON_ADD["onPluginAdded()"]
        ON_MOD["onPluginModified()"]
        ON_REM["onPluginRemoved()"]
    end

    subgraph Actions["⚡ Actions"]
        LOAD["loadAndInitialize()<br/>• Copy to temp<br/>• Load JAR<br/>• Create instance"]

        RELOAD["Hot-Reload<br/>• Save enabled state<br/>• unloadPlugin()<br/>• loadAndInitialize()<br/>• Re-enable if was enabled"]

        UNLOAD["unloadPlugin()<br/>• Call @OnShutdown<br/>• Unregister handlers<br/>• Close ClassLoader"]
    end

    subgraph Sync["🔄 Discord Sync (Two-Tier)"]
        SYNC_GLOBAL["syncCommands()<br/>core→global"]
        SYNC_GUILDS["syncCommands()<br/>plugins→per-guild<br/>(respects disabled_plugins)"]
    end

    %% File system connections
    PLUGINS_DIR --> WATCH
    JAR_NEW --> CREATE
    JAR_MODIFY --> MODIFY
    JAR_DELETE --> DELETE

    %% Watcher loop
    WATCH --> POLL
    POLL --> Events

    %% Events to callbacks
    CREATE --> ON_ADD
    MODIFY --> ON_MOD
    DELETE --> ON_REM

    %% Callbacks to actions
    ON_ADD --> LOAD
    ON_MOD --> RELOAD
    ON_REM --> UNLOAD

    %% Actions to sync
    LOAD --> SYNC_GLOBAL
    LOAD --> SYNC_GUILDS
    RELOAD --> SYNC_GLOBAL
    RELOAD --> SYNC_GUILDS
    UNLOAD --> SYNC_GLOBAL
    UNLOAD --> SYNC_GUILDS

    %% Styling
    classDef file fill:#1e3a5f,stroke:#4a90d9,color:#fff
    classDef watcher fill:#5a3d5a,stroke:#9c27b0,color:#fff
    classDef event fill:#3d5a3d,stroke:#4CAF50,color:#fff
    classDef callback fill:#5a4d3d,stroke:#ff9800,color:#fff
    classDef action fill:#3d3d5a,stroke:#2196F3,color:#fff
    classDef sync fill:#5a3d3d,stroke:#f44336,color:#fff

    class PLUGINS_DIR,JAR_NEW,JAR_MODIFY,JAR_DELETE file
    class WATCH,POLL watcher
    class CREATE,MODIFY,DELETE event
    class ON_ADD,ON_MOD,ON_REM callback
    class LOAD,RELOAD,UNLOAD action
    class SYNC_GLOBAL,SYNC_GUILDS sync
