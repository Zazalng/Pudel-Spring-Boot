%% Pudel System Overview v2.1.1
%% Two-Tier Plugin Control + Components V2

flowchart TB
    subgraph Users["👥 Users"]
        DISCORD_USER["Discord User"]
        GUILD_ADMIN["Guild Admin"]
        BOT_ADMIN["Bot Admin"]
        DEVELOPER["Plugin Developer"]
    end

    subgraph Discord["🎮 Discord"]
        DG["Discord Gateway"]
        SLASH["Slash Commands"]
        TEXT["Text Commands"]
        CV2["Components V2<br/>Buttons / Modals /<br/>EntitySelectMenu"]
    end

    subgraph Pudel["🐩 Pudel v2.2.1"]
        subgraph Core["pudel-core"]
            JDA["JDA 6<br/>(Discord API)"]
            SPRING["Spring Boot 4"]

            subgraph PluginSys["Plugin System"]
                LOADER["PluginClassLoader"]
                PROCESSOR["AnnotationProcessor"]
                PLUGIN_SVC["PluginService<br/>(global lifecycle)"]
                WATCHER["PluginWatcherService<br/>(hot-reload)"]
            end

            subgraph Commands["Command System"]
                BUILTIN["BuiltinCommands<br/>Components V2 Panel<br/>/settings"]
                INTERACT_MGR["InteractionManagerImpl<br/>Two-tier sync:<br/>core→global, plugin→guild"]
                CMD_REG["CommandRegistry"]
            end

            subgraph REST["REST API Controllers"]
                ADMIN_CTRL["AdminController<br/>(global plugin mgmt)"]
                GUILD_CTRL["GuildSettingsController<br/>(guild plugin toggle)"]
                AUTH_CTRL["AuthController"]
            end

            subgraph Brain["AI Brain"]
                BRAIN["PudelBrain"]
                MEMORY["MemoryManager"]
            end

            subgraph GuildData["Guild Settings"]
                GUILD_SETTINGS["GuildSettings<br/>disabled_plugins CSV<br/>disabled_commands CSV"]
                GUILD_SVC["GuildSettingsService"]
            end
        end

        subgraph Model["pudel-model"]
            OLLAMA_CLIENT["OllamaClient"]
            ANALYZER["TextAnalyzer"]
            AGENT["AgentService"]
        end

        subgraph API["pudel-api (MIT)"]
            ANNOTATIONS["@Plugin @SlashCommand<br/>@ButtonHandler @ModalHandler<br/>@TextCommand @OnEnable<br/>@OnShutdown"]
        end

        subgraph Plugins["External Plugins"]
            PLUGIN1["🎵 Music Plugin"]
            PLUGIN2["🛡️ Moderation Plugin"]
            PLUGIN3["🔧 Custom Plugin"]
        end
    end

    subgraph Infrastructure["🏗️ Infrastructure"]
        DB[(PostgreSQL<br/>+ pgvector)]
        LLM["Ollama<br/>(Local LLM)"]
        VUE["Vue Dashboard"]
    end

    %% User flows
    DISCORD_USER --> DG
    GUILD_ADMIN --> DG
    GUILD_ADMIN --> VUE
    BOT_ADMIN --> VUE
    DEVELOPER -->|"Create JAR"| Plugins

    %% Discord to Pudel
    DG --> JDA
    SLASH --> INTERACT_MGR
    TEXT --> CMD_REG
    CV2 --> INTERACT_MGR

    %% Plugin system
    LOADER --> PROCESSOR
    PROCESSOR --> PLUGIN_SVC
    WATCHER --> LOADER
    Plugins --> LOADER
    ANNOTATIONS --> Plugins

    %% Commands
    BUILTIN --> INTERACT_MGR
    PLUGIN_SVC --> Commands

    %% Two-tier control
    ADMIN_CTRL --> PLUGIN_SVC
    GUILD_CTRL --> GUILD_SVC
    GUILD_SVC --> GUILD_SETTINGS
    GUILD_SETTINGS --> INTERACT_MGR
    BUILTIN --> GUILD_SVC

    %% REST API
    VUE --> REST
    REST --> DB

    %% AI flow
    Brain --> Model
    OLLAMA_CLIENT --> LLM
    MEMORY --> DB

    %% Styling
    classDef user fill:#1565c0,stroke:#0d47a1,color:#fff
    classDef discord fill:#5865F2,stroke:#4752C4,color:#fff
    classDef core fill:#2e7d32,stroke:#1b5e20,color:#fff
    classDef model fill:#7b1fa2,stroke:#4a148c,color:#fff
    classDef api fill:#00796b,stroke:#004d40,color:#fff
    classDef plugin fill:#f57c00,stroke:#e65100,color:#fff
    classDef infra fill:#455a64,stroke:#263238,color:#fff

    class DISCORD_USER,GUILD_ADMIN,BOT_ADMIN,DEVELOPER user
    class DG,SLASH,TEXT,CV2 discord
    class JDA,SPRING,LOADER,PROCESSOR,PLUGIN_SVC,WATCHER,BUILTIN,INTERACT_MGR,CMD_REG,ADMIN_CTRL,GUILD_CTRL,AUTH_CTRL,BRAIN,MEMORY,GUILD_SETTINGS,GUILD_SVC core
    class OLLAMA_CLIENT,ANALYZER,AGENT model
    class ANNOTATIONS api
    class PLUGIN1,PLUGIN2,PLUGIN3 plugin
    class DB,LLM,VUE infra
